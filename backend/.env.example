# Copy to .env and fill in values

# Set to true for SQL query logs
DEBUG=false

# Ollama endpoint (change if running on a different host/port)
OLLAMA_BASE_URL=http://localhost:11434

# HuggingFace token. Optional for open models, but REQUIRED to download
# gated models such as FLUX.1-dev and Stable Diffusion 3.5 (you must also
# accept their license on the model's HF page). Used by the image-model
# connector and dataset downloads.
HUGGINGFACE_TOKEN=

# Optional: Kaggle credentials (for downloading Kaggle datasets)
KAGGLE_USERNAME=
KAGGLE_KEY=

# Security: optional shared token. When set, REST requests must send the
# `X-API-Token` header and WebSocket clients must pass `?token=...`.
# For the frontend to send it, build with VITE_API_TOKEN=<same value>.
API_TOKEN=

# Agent code execution runs arbitrary Python — disabled by default.
ENABLE_CODE_EXECUTOR=false
CODE_EXECUTOR_TIMEOUT=15
CODE_EXECUTOR_MAX_MEMORY_MB=512

# Refuse Hugging Face model downloads below this free-disk margin (MB).
MIN_FREE_DISK_MB=2048
