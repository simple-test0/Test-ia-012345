# Copy to .env and fill in values

# Set to true for SQL query logs
DEBUG=false

# Ollama endpoint (change if running on a different host/port)
OLLAMA_BASE_URL=http://localhost:11434

# Optional: HuggingFace token for private models/datasets
HUGGINGFACE_TOKEN=

# Optional: Kaggle credentials (for downloading Kaggle datasets)
KAGGLE_USERNAME=
KAGGLE_KEY=
