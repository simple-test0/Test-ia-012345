# Copy to .env and fill in values

# Set to true for SQL query logs
DEBUG=false

# Ollama endpoint (change if running on a different host/port)
OLLAMA_BASE_URL=http://localhost:11434

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Compute device override. Empty = autodetect (CUDA > ROCm > XPU > MPS > CPU).
# Examples: cpu | cuda:0 | cuda:1 | mps | xpu
DEVICE_PREFERENCE=

# Opt-in torch.compile for image pipelines (slow first run, faster afterwards)
ENABLE_TORCH_COMPILE=false

# How many diffusion pipelines may stay resident in memory (LRU eviction)
MAX_PIPELINES_LOADED=1

# Safety guardrails
MAX_IMAGE_MEGAPIXELS=4.2
MAX_UPLOAD_MB=512

# Optional: HuggingFace token for private models/datasets
HUGGINGFACE_TOKEN=

# Optional: Kaggle credentials (for downloading Kaggle datasets)
KAGGLE_USERNAME=
KAGGLE_KEY=
